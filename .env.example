# bybit-cli API Credentials Example
# Rename this file to .env and fill in your keys.
# NEVER commit your actual .env file to version control.

# Required: Bybit API Key and Secret
BYBIT_API_KEY="your_api_key_here"
BYBIT_API_SECRET="your_api_secret_here"

# Optional: Set to true to use the Bybit Testnet
BYBIT_TESTNET=false

# Optional: Default category (linear, spot, inverse, option)
BYBIT_DEFAULT_CATEGORY="linear"

# Optional: Default output format (table, json)
BYBIT_OUTPUT="table"
